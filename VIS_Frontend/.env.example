# API base URL (Python backend - document process, summarize, Q&A)
VITE_API_URL=http://localhost:8000

# If your Python backend uses a path prefix (e.g. /api/process instead of /process), set it:
# VITE_API_DOCUMENT_PREFIX=/api

# Voice/TTS backend (VIS_Backend - Node, Google TTS). Used for POST /api/tts only.
VITE_API_URL_VOICE=http://localhost:5000

# Set to "true" to use Google Cloud Text-to-Speech via VITE_API_URL_VOICE /api/tts.
# When false or unset, the app uses browser Speech API (en-IN/en-GB when available) or mock TTS.
VITE_USE_GOOGLE_TTS=false

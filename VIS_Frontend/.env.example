# Set to "true" to use Google Cloud Text-to-Speech via VITE_API_URL_VOICE /api/tts.
VITE_USE_GOOGLE_TTS=false

# 1. Voice/TTS backend (VIS_Backend - Node)
VITE_API_URL_VOICE=http://localhost:5000

# 2. Braille microservice (decode, evaluate)
VITE_API_URL_BRAILLE=http://localhost:8000

# 3. Document microservice (Python - process, summarize, Q&A)
VITE_API_URL_DOCUMENT=http://localhost:8000

# 4. History microservice (audio lessons)
VITE_API_URL_HISTORY=http://localhost:8004

# 5. Quiz microservice (voice quiz)
VITE_API_URL_QUIZ=http://localhost:8000

# If document backend uses a path prefix (e.g. /api/process), set:
# VITE_API_DOCUMENT_PREFIX=/api
